# Template — copie para `.env` e preencha com os valores reais localmente
# (o `.env` preenchido nunca deve ser commitado). Em produção, essas
# variáveis são configuradas como Secrets direto no painel do Supabase
# (Edge Functions > Secrets), não a partir deste arquivo. Necessário
# localmente só para `supabase functions serve`.
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Segredo compartilhado para autenticar chamadas ao cron
# (sync-clint, analyze-conversation-sweep, analyze-conversation-review,
# analysis-batch-submit, analysis-batch-poll)
CRON_SECRET=<cron-secret>

# CRM (confirmar nome/documentação da API — ainda não usado por nenhuma function)
CRM_BASE_URL=
CRM_API_KEY=

# Clint (conversas/mensagens de WhatsApp/Instagram) — usado por sync-clint
CLINT_BASE_URL=https://api.clint.digital
CLINT_API_KEY=<clint-api-key>

# WhatsApp (confirmar provedor — sync-whatsapp ainda é um esqueleto,
# sync-clint cobre a ingestão real via API do Clint)
WHATSAPP_WEBHOOK_SECRET=

# Motor de análise (Gemini)
GEMINI_API_KEY=<gemini-api-key>
